# Django
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=.elb.amazonaws.com,.cloudfront.net,localhost
# CloudFront now fronts the ALB directly; admin POSTs arrive via this origin.
DJANGO_CSRF_TRUSTED_ORIGINS=https://edison-blog.maxcharlesjr.com
# Static assets (admin CSS/JS/img) are served from S3 via CloudFront's /static/* behavior.
DJANGO_STATIC_URL=https://edison-blog.maxcharlesjr.com/static/

# Database (Amazon RDS for MySQL). Omit DB_ENGINE to fall back to SQLite locally.
DB_ENGINE=mysql
DB_NAME=dailyedison
DB_USER=admin
DB_PASSWORD=replace-with-rds-password
DB_HOST=dailyedison.abcdefg.us-east-1.rds.amazonaws.com
DB_PORT=3306
